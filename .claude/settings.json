{
  "permissions": {
    "allow": [
      "Bash(node_modules/.bin/ng build*)",
      "Bash(npm run build*)"
    ]
  },
  "env": {
    "npm_config_prefer_offline": "true",
    "npm_config_audit": "false",
    "npm_config_fund": "false"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /tmp/cc-agent/58255875/project && npm run build 2>&1 | tail -5",
            "timeout": 120,
            "statusMessage": "Building project..."
          }
        ]
      }
    ]
  }
}
